{
  "name": "commandcode-go-around",
  "version": "0.1.0",
  "type": "module",
  "description": "CLI shim to use Command Code Go models from OpenCode through a local OpenAI-compatible bridge",
  "bin": {
    "ccga": "./bin/commandcode-shim.js",
    "commandcode-go-around": "./bin/commandcode-shim.js",
    "commandcode-shim": "./bin/commandcode-shim.js"
  },
  "files": [
    "bin",
    "src",
    "server.mjs",
    "README.md"
  ],
  "scripts": {
    "start": "node ./bin/commandcode-shim.js serve",
    "pack:dry-run": "npm pack --dry-run"
  },
  "publishConfig": {
